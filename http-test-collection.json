  "item": [
    { "name": "1. GET Todas", "request": { "method": "GET", "url": { "raw": "http://localhost:3000/api/tareas", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas"] } } },
    { "name": "2. GET por ID", "request": { "method": "GET", "url": { "raw": "http://localhost:3000/api/tareas/1", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas", "1"] } } },
    { "name": "3. POST Crear", "request": { "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Nueva tarea\",\n  \"completada\": false\n}" }, "url": { "raw": "http://localhost:3000/api/tareas", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas"] } } },
    { "name": "4. PUT Completa", "request": { "method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Tarea actualizada\",\n  \"completada\": true\n}" }, "url": { "raw": "http://localhost:3000/api/tareas/1", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas", "1"] } } },
    { "name": "5. PATCH Parcial", "request": { "method": "PATCH", "header": [{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\n  \"completada\": true\n}" }, "url": { "raw": "http://localhost:3000/api/tareas/1", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas", "1"] } } },
    { "name": "6. DELETE", "request": { "method": "DELETE", "url": { "raw": "http://localhost:3000/api/tareas/3", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas", "3"] } } },
    { "name": "7. GET Buscar (Actividad 3)", "request": { "method": "GET", "url": { "raw": "http://localhost:3000/api/tareas/buscar?q=express", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas", "buscar"], "query": [{"key": "q", "value": "express"}] } } },
    { "name": "8. GET Texto (Actividad 4)", "request": { "method": "GET", "url": { "raw": "http://localhost:3000/api/tareas?formato=text", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "tareas"], "query": [{"key": "formato", "value": "text"}] } } },
